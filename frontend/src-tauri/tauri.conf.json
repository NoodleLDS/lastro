{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lastro",
  "version": "0.1.0",
  "identifier": "app.lastro.desktop",
  "build": {
    "frontendDist": "http://localhost:5180",
    "devUrl": "http://localhost:5180"
  },
  "app": {
    "windows": [
      {
        "title": "Lastro",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
