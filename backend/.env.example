# Backend environment variables — copy this file to .env and fill in your values.
# Never commit the actual .env file.

# Token para a API brapi.dev (cotações B3). Crie uma conta gratuita em https://brapi.dev
LASTRO_BRAPI_TOKEN=your_brapi_token_here

# Usuário e senha do painel admin (acesso local apenas)
LASTRO_ADMIN_USERNAME=admin
LASTRO_ADMIN_PASSWORD=change_me

# Segredo JWT — gere com: python -c "import secrets; print(secrets.token_urlsafe(32))"
LASTRO_JWT_SECRET=change_me_generate_a_random_secret

# Provider de IA: "ollama" (local, padrão) ou "claude" (requer LASTRO_CLAUDE_API_KEY)
LASTRO_LLM_PROVIDER=ollama

# API key da Anthropic — só necessária se LASTRO_LLM_PROVIDER=claude
# LASTRO_CLAUDE_API_KEY=sk-ant-...
